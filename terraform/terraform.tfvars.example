# Example variable values - copy to terraform.tfvars and customize

aws_region       = "us-east-1"
environment      = "dev"
cluster_name     = "matrix-eks-cluster"
vpc_cidr         = "10.0.0.0/16"
instance_type    = "t3.small"
desired_capacity = 2
min_capacity     = 2
max_capacity     = 3
k8s_namespace    = "matrix"
