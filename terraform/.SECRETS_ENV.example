# Secrets Environment File - EXAMPLE
# Copy this file to .SECRETS_ENV and fill in your actual secret values
# 
# Usage:
#   1. cp .SECRETS_ENV.example .SECRETS_ENV
#   2. Edit .SECRETS_ENV with your actual secrets
#   3. source .SECRETS_ENV
#   4. terraform plan/apply
#
# IMPORTANT: .SECRETS_ENV is in .gitignore - never commit it!

# Database Secrets
# Generate strong password: openssl rand -base64 32
export TF_VAR_postgres_password="CHANGE_ME_generate_strong_password_min_16_chars"
export TF_VAR_postgres_user="synapse"
export TF_VAR_postgres_db="synapse"

# Matrix Synapse Configuration
# Your domain name (e.g., matrix.example.com)
export TF_VAR_synapse_server_name="matrix.example.com"

# Generate random secrets: openssl rand -base64 32
export TF_VAR_synapse_registration_shared_secret="CHANGE_ME_generate_random_string_min_32_chars"
export TF_VAR_synapse_macaroon_secret_key="CHANGE_ME_generate_random_string_min_32_chars"

# Quick setup script:
# Run these commands to generate secure secrets:
#
# export TF_VAR_postgres_password=$(openssl rand -base64 32)
# export TF_VAR_synapse_registration_shared_secret=$(openssl rand -base64 32)
# export TF_VAR_synapse_macaroon_secret_key=$(openssl rand -base64 32)
# export TF_VAR_synapse_server_name="matrix.yourdomain.com"
# export TF_VAR_postgres_user="synapse"
# export TF_VAR_postgres_db="synapse"
